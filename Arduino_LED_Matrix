// ================= FLOW ANIMATION =================
void flow(byte frame[8][12]) {

  byte temp[8][12];

  for (int shift = -12; shift <= 12; shift++) {

    memset(temp, 0, sizeof(temp));

    for (int y = 0; y < 8; y++) {
      for (int x = 0; x < 12; x++) {
        int nx = x + shift;

        if (nx >= 0 && nx < 12) {
          temp[y][nx] = frame[y][x];
        }
      }
    }

    matrix.renderBitmap(temp, 8, 12);

    delay(85); // 🔥 smooth slow walking
  }
}

void loop() {

  flow(heart);

  flow(one);
  flow(two);
  flow(three);
  flow(four);
  flow(five);
  flow(six);
  flow(seven);
  flow(eight);
  flow(nine);
  flow(zero);
}
